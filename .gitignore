# --- Gradle ---
.gradle/
build/

# --- Android ---
*.iml
.idea/
/captures
.externalNativeBuild
.cxx
local.properties
app/build/

# --- Build artifacts kept on disk but not in version control ---
# The dev APK is copied to ./intentcam.apk after each build (per project memory).
# It is large (~107 MB) and rebuilt often, so exclude it from the repo and
# document the build steps in README instead.
*.apk
*.aab
*.ap_
*.dex

# --- Logs / temp ---
*.log
*.hprof
.kotlin/

# --- OS / IDE ---
.DS_Store
Thumbs.db

# --- Tool-specific state ---
# Claude session state — contains user preferences and history, not part of
# the project.  Recreated automatically per session.
.claude/

# --- Eval archive ---
# Local-only eval data (smoke tests, superseded iterations) preserved on disk
# but not in version control. Leading-underscore convention matches the
# `profiling/_*_<tag>.log` pattern in [[feedback-529-contamination-awareness]].
profiling/_archive/

# --- Auth tokens (per user request) ---
# Models.kt has the LLM API token baked in so the debug APK runs out of
# the box.  The file is gitignored so the token never lands in the public
# GitHub repository.  The previous version of Models.kt (with the token
# scrubbed) is still in git history.
app/src/main/java/com/example/intentcam/Models.kt
__pycache__/

# --- AGC credentials (Huawei AppGallery Connect) ---
# NEVER commit this — it's bundled into the APK and contains OAuth secrets.
app/src/main/assets/agconnect-services.json
